# Copy to .env.local to enable optional local features.

# Universal Property Scanner — Browser Automation Provider (Playwright).
# Free, local-only, opt-in. Renders Zillow/Redfin/Realtor in a real local
# Chromium and becomes the primary search provider. Requires a one-time
# `npm run scanner:install` to download the Chromium binary.
# Unset/0 = the scanner uses the static + CSV/PDF providers only (default).
SCANNER_BROWSER=0

# Set to 1 to run the browser non-headless (watch it work) for debugging.
SCANNER_BROWSER_HEADFUL=0
